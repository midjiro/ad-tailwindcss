{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "extends": ["./oxlintrc.base.json"],
    "plugins": ["typescript", "node"],
    "env": {
        "node": true
    },
    "overrides": [
        {
            "files": ["src/**/*.ts"],
            "rules": {
                "typescript/consistent-type-imports": [
                    "warn",
                    {
                        "prefer": "type-imports",
                        "fixStyle": "inline-type-imports"
                    }
                ],
                "typescript/no-extraneous-class": "warn"
            }
        }
    ]
}
